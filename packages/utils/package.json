{
  "name": "@jsoc/utils",
  "version": "0.0.0",
  "description": "Utility functions used within the JSOC Grid repository.",
  "keywords": [
    "utility"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsoc-dev/grid.git",
    "directory": "packages/utils"
  },
  "bugs": {
    "url": "https://github.com/jsoc-dev/grid/issues"
  },
  "homepage": "https://github.com/jsoc-dev/grid/tree/main/packages/utils#readme",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
