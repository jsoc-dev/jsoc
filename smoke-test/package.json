{
  "name": "smoke-test",
  "private": true,
  "type": "module",
  "dependencies": {
    "@jsoc/grid-core": "file:./packages/jsoc-grid-core.tgz",
    "@jsoc/react-grid": "file:./packages/jsoc-react-grid.tgz",
    "@jsoc/utils": "file:./packages/jsoc-utils.tgz",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.0.7"
  },
  "scripts": {
    "install:isolated": "pnpm install --ignore-workspace",
    "pack": "pnpm -w build run && pnpm -w --filter \"../packages/**\" pack --out ./smoke-test/packages/%s.tgz",
    "test": "pnpm run pack && pnpm run install:isolated && vitest run"
  },
  "pnpm": {
    "overrides": {
      "@jsoc/grid-core": "file:./packages/jsoc-grid-core.tgz",
      "@jsoc/utils": "file:./packages/jsoc-utils.tgz"
    }
  }
}
